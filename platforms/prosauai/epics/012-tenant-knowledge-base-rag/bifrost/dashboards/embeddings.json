{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "datasource", "uid": "grafana"},
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Bifrost OpenAI embeddings — RPS, p95 latency, accumulated spend per tenant, and rate-limit usage. Epic 012 T080.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Embeddings calls per second, by HTTP status code. Sustained spikes can presage rate-limit rejections.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "req/s", "drawStyle": "line", "lineWidth": 1, "fillOpacity": 10},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (status) (rate(bifrost_request_duration_seconds_count{endpoint=\"embeddings\"}[1m]))",
          "legendFormat": "status={{status}}",
          "refId": "A"
        }
      ],
      "title": "Embeddings — Requests per second (by status)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "p50 / p95 / p99 of upstream embeddings call duration (Bifrost-measured, not OpenAI client SDK). Alerts fire on p95 > 1.5 s for 5 min.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "seconds", "drawStyle": "line", "lineWidth": 1, "fillOpacity": 5},
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(bifrost_request_duration_seconds_bucket{endpoint=\"embeddings\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(bifrost_request_duration_seconds_bucket{endpoint=\"embeddings\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(bifrost_request_duration_seconds_bucket{endpoint=\"embeddings\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Embeddings — Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_BIFROST_PG}"},
      "description": "Accumulated USD spend per tenant for the selected time range. Sourced from bifrost_spend (writes guarded by FR-032). Diff vs OpenAI invoice MUST stay within 2 % (SC-010).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"axisLabel": "USD", "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "stacking": {"mode": "normal"}},
          "decimals": 4,
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {"legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT date_trunc('hour', created_at) AS time, tenant_slug AS metric, sum(total_cost_usd) AS value FROM bifrost_spend WHERE endpoint = 'embeddings' AND $__timeFilter(created_at) GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ],
      "title": "Embeddings — Cumulative spend per tenant (USD)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Current usage of the per-tenant rate-limit window as a percentage of the configured ceiling (3500 RPM, 5M TPM). > 80 % means the cron is at risk of 429s — investigate batch sizes.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "decimals": 1,
          "max": 100,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "orange", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 8},
      "id": 4,
      "options": {"orientation": "horizontal", "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "expr": "100 * (sum by (tenant) (rate(bifrost_request_duration_seconds_count{endpoint=\"embeddings\"}[1m])) * 60) / 3500",
          "legendFormat": "{{tenant}}",
          "refId": "A"
        }
      ],
      "title": "Rate-limit usage — RPM (% of 3500)",
      "type": "gauge"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Counter of requests rejected before reaching upstream — 'breaker_open', 'rate_limited', 'missing_tenant_header'. Spikes indicate misconfiguration or upstream incidents.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "stacking": {"mode": "normal"}},
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 8},
      "id": 5,
      "options": {"legend": {"displayMode": "table", "placement": "bottom"}, "tooltip": {"mode": "multi"}},
      "targets": [
        {
          "expr": "sum by (reason) (rate(bifrost_requests_rejected_total{endpoint=\"embeddings\"}[1m]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Embeddings — Rejected requests / sec (by reason)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["bifrost", "epic-012", "rag", "embeddings"],
  "templating": {
