{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://madruga.ai/schemas/screen-flow/v1.json",
  "title": "ScreenFlow",
  "description": "YAML por plataforma descrevendo telas (body components), transições (flows/edges), e estado de captura. Vocabulário fechado v1 — locked nas decisões 1-way-door da pitch.md (D1-D26).",
  "type": "object",
  "required": ["schema_version", "meta", "screens", "flows"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "integer",
      "enum": [1],
      "description": "Versão do schema. Validator rejeita ausência ou versão desconhecida (FR-002)."
    },
    "meta": {
      "type": "object",
      "required": ["device", "capture_profile"],
      "additionalProperties": false,
      "properties": {
        "device": {
          "type": "string",
          "enum": ["mobile", "desktop"]
        },
        "capture_profile": {
          "type": "string",
          "enum": ["iphone-15", "desktop"]
        },
        "layout_direction": {
          "type": "string",
          "enum": ["DOWN", "RIGHT"],
          "default": "DOWN"
        }
      }
    },
    "screens": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": { "$ref": "#/$defs/Screen" }
    },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/Flow" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "description": "Charset locked: lowercase, começa com letra, max 64 chars, apenas underscore separador (FR-048)."
    },
    "Screen": {
      "type": "object",
      "required": ["id", "title", "status", "body"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "title": { "type": "string", "minLength": 1, "maxLength": 100 },
        "status": {
          "type": "string",
          "enum": ["pending", "captured", "failed"]
        },
        "body": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/BodyComponent" }
        },
        "image": {
          "type": "string",
          "description": "Path relativo ao repo do PNG capturado (LFS)."
        },
        "position": {
          "type": "object",
          "required": ["x", "y"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" }
          }
        },
        "meta": { "$ref": "#/$defs/ScreenMeta" },
        "capture": { "$ref": "#/$defs/CaptureRecord" },
        "failure": { "$ref": "#/$defs/CaptureFailure" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "captured" } } },
          "then": { "required": ["image", "capture"] }
        },
        {
          "if": { "properties": { "status": { "const": "failed" } } },
          "then": { "required": ["failure"] }
        }
      ]
    },
    "ScreenMeta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "route": { "type": "string" },
        "entrypoint": { "type": "string" },
        "capture_profile": {
          "type": "string",
          "enum": ["iphone-15", "desktop"]
        },
        "wait_for": {
          "type": "string",
          "description": "CSS selector para aguardar antes de capturar."
        }
      }
    },
    "BodyComponent": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "heading",
            "text",
            "input",
            "button",
            "link",
            "list",
            "card",
            "image",
            "divider",
            "badge"
          ],
          "description": "Vocabulário fechado de 10 (Decision #5)."
        },
        "id": { "$ref": "#/$defs/id" },
        "text": { "type": "string" },
        "testid": {
          "type": "string",
          "description": "Reference a testID JÁ EXISTENTE no app (sem nova convenção). Capture usa [data-testid=<this>] para boundingBox de hotspot (FR-028)."
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "Flow": {
      "type": "object",
      "required": ["from", "to", "on", "style"],
      "additionalProperties": false,
      "properties": {
        "from": { "$ref": "#/$defs/id" },
        "to": { "$ref": "#/$defs/id" },
        "on": { "$ref": "#/$defs/id" },
        "style": {
          "type": "string",
          "enum": ["success", "error", "neutral", "modal"],
          "description": "Vocabulário fechado de 4 (Decision #5)."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "maxLength": 50
        }
      }
    },
    "CaptureRecord": {
      "type": "object",
      "required": ["captured_at", "app_version", "image_md5", "viewport"],
      "additionalProperties": false,
      "properties": {
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "app_version": {
          "type": "string",
          "description": "Git SHA curto do app no momento da captura."
        },
        "image_md5": {
          "type": "string",
          "pattern": "^[0-9a-f]{32}$"
        },
        "viewport": {
          "type": "object",
          "required": ["w", "h"],
          "additionalProperties": false,
          "properties": {
            "w": { "type": "integer", "minimum": 1 },
            "h": { "type": "integer", "minimum": 1 }
          }
        }
      }
    },
    "CaptureFailure": {
      "type": "object",
      "required": ["reason", "occurred_at", "retry_count"],
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "enum": [
            "timeout",
            "auth_expired",
            "network_error",
            "app_crash",
            "sw_cleanup_failed",
            "mock_route_unmatched",
            "unknown"
          ]
        },
        "occurred_at": {
          "type": "string",
          "format": "date-time"
        },
        "retry_count": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3
        },
        "last_error_message": {
          "type": "string",
          "maxLength": 500
        }
      }
    }
  }
}
