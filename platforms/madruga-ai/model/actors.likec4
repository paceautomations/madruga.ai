model {

  architect = person 'Arquiteto / Engenheiro' {
    description 'Usa skills interativamente via Claude Code para documentar arquitetura, gerar specs, e executar pipeline spec-to-code'
  }

  daemon = person 'Daemon Autonomo' {
    description 'Processo asyncio 24/7 que executa pipeline spec-to-code autonomamente via DAG Executor + claude -p, lendo pipeline de platform.yaml e notificando resultados via Telegram'
  }
}
