views {

  // ══════════════════════════════════════
  //  STRUCTURAL VIEWS (o que existe)
  // ══════════════════════════════════════

  view index {
    title 'Madruga AI — System Landscape'
    description 'Visao geral: atores, plataforma, sistemas externos e infraestrutura'

    include architect, easter
    include madrugaAi
    include claudeApi, telegramBot, githubApi, likec4Cli, sentryCloud
    include sqliteDb, gitFs
  }

  view containers of madrugaAi {
    title 'C4 L2 — Containers & Integrations'
    description 'Containers deployaveis, storage, sistemas externos e mapa completo de integracoes'

    include *
    include architect, easter
    include claudeApi, telegramBot, githubApi, likec4Cli, sentryCloud
    include sqliteDb, gitFs
  }

  view contextMap {
    title 'DDD Context Map'
    description 'Bounded contexts, relacoes DDD (ACL, Conformist, Customer-Supplier, Pub-Sub)'

    include documentation, documentation.*
    include specDomain, specDomain.*
    include execution, execution.*
    include intelligence, intelligence.*
    include integration, integration.*
    include observability, observability.*
    include architect, easter
    include claudeApi, telegramBot, githubApi, likec4Cli, sentryCloud
    include sqliteDb, gitFs
  }

  // ── Scoped Views (zoom por bounded context) ──

  view documentationDetail of documentation {
    title 'Documentation — Core Domain'
    description 'Bounded context Documentation: scaffold, portal, model pipeline, AUTO markers'

    include *
    include likec4Cli, gitFs
  }

  view specificationDetail of specDomain {
    title 'Specification — Core Domain'
    description 'Bounded context Specification: specify, plan, tasks, clarify, analyze'

    include *
    include intelligence.subagentJudgeModule, intelligence.decisionModule
  }

  view executionDetail of execution {
    title 'Execution — Supporting Domain'
    description 'Bounded context Execution: easter (FastAPI), DAG executor (MADRUGA_MODE)'

    include *
    include integration.claudeClient, integration.telegramAdapter
    include sqliteDb
    include claudeApi
  }

  view intelligenceDetail of intelligence {
    title 'Intelligence — Supporting Domain'
    description 'Bounded context Intelligence: Subagent Judge (ADR-019), Decision Classifier, Stress Test'

    include *
    include claudeApi
  }

  view integrationDetail of integration {
    title 'Integration — Generic Domain'
    description 'Adapters para sistemas externos: Telegram, GitHub, Claude API, Sentry'

    include *
    include claudeApi, telegramBot, githubApi, sentryCloud
  }

  view observabilityDetail of observability {
    title 'Observability — Generic Domain'
    description 'Dashboard, health checks, metricas SQLite, Sentry'

    include *
    include sqliteDb, sentryCloud
  }

  // ══════════════════════════════════════
  //  FLUXO DE NEGOCIO (pipeline spec-to-code)
  // ══════════════════════════════════════

  dynamic view businessFlow {
    title 'Spec-to-Code Pipeline — Fluxo Completo'
    description 'Pipeline autonomo: DAG executor le platform.yaml → resolve deps → despacha nodes via claude -p → human gates pausam → Telegram notifica → resume. 7 fases, 2 loops de feedback, 1 reconciliation final.'

    autoLayout TopBottom

    // ════════════════════════════════════
    //  FASE 1: TRIGGER (DAG Executor → Pipeline)
    // ════════════════════════════════════

    execution.dagExecutor -> execution.easterProcess 'Node pronto (deps satisfeitas)' {
      notes '''
        **DAG Executor trigger**
        - Le pipeline nodes de platform.yaml
        - Resolve dependencias via topological sort
        - Verifica status no SQLite (skip nodes ja concluidos)
        - Despacha node via claude -p (3 modos: MADRUGA_MODE)
        - Human gates: manual (DB wait), interactive (y/n), auto (skip)
      '''
    }

    // ════════════════════════════════════
    //  FASE 2: SPECIFY (pitch → spec.md)
    // ════════════════════════════════════

    execution.dagExecutor -> specDomain.specifyPhase 'Pitch + constitution' {
      notes '''
        **Specify Phase**
        - DAG Executor compoe prompt com pitch + constitution (compose_skill_prompt)
        - Claude gera spec.md estruturada
        - Artefato MECE: owner = specifyPhase, purpose = "o que construir"
      '''
    }

    // ════════════════════════════════════
    //  FASE 3: CLARIFY (spec → perguntas → spec atualizada)
    // ════════════════════════════════════

    specDomain.specifyPhase -> specDomain.clarifyEngine 'spec.md draft' {
      notes '''
        **Clarify Loop**
        - Identifica ate 5 areas sub-especificadas
        - Gera perguntas targetadas
        - Encoda respostas de volta na spec
        - Loop ate spec estar "complete"
      '''
    }

    // ════════════════════════════════════
    //  FASE 4: REVIEW (spec → Subagent Judge → spec melhorada)
    // ════════════════════════════════════

    specDomain.clarifyEngine -> intelligence.subagentJudgeModule 'spec.md clarificada' {
      notes '''
        **Subagent Judge (ADR-019)**
        - 4 personas paralelas: Architecture Reviewer, Bug Hunter, Simplifier, Stress Tester
        - 1 Judge pass filtra por Accuracy, Actionability, Severity
        - Output: BLOCKER / WARNING / NIT
        - BLOCKERs devem ser resolvidos antes de prosseguir
      '''
    }

    // ════════════════════════════════════
    //  FASE 5: PLAN (spec → plan.md)
    // ════════════════════════════════════

    intelligence.subagentJudgeModule -> specDomain.planPhase 'spec.md aprovada (sem BLOCKERs)' {
      notes '''
        **Plan Phase**
        - Gera plan.md com design detalhado
        - Componentes, interfaces, fluxos, decisoes tecnicas
        - Decision System classifica 1-way/2-way doors
        - ADRs gerados automaticamente para 1-way doors
      '''
    }

    specDomain.planPhase -> intelligence.decisionModule 'Decisoes detectadas no plan' {
      notes '''
        **Decision Classification**
        - 1-way door: irreversivel, requer ADR formal
        - 2-way door: reversivel, documenta inline
        - Auto-gera ADRs no formato Nygard
      '''
    }

    // ════════════════════════════════════
    //  FASE 6: TASKS (plan → tasks.md)
    // ════════════════════════════════════

    intelligence.decisionModule -> specDomain.tasksPhase 'plan.md + ADRs' {
      notes '''
        **Tasks Phase**
        - Gera tasks.md com tarefas ordenadas por dependencia
        - Cada task: descricao, estimativa, acceptance criteria
        - Analyze verifica consistencia spec ↔ plan ↔ tasks
      '''
    }

    specDomain.tasksPhase -> specDomain.analyzeEngine 'tasks.md gerado' {
      notes '''
        **Cross-artifact analysis**
        - Verifica consistencia entre spec.md, plan.md, tasks.md
        - Detecta gaps, contradicoes, requirements nao cobertos
        - Output: lista de issues com severidade
      '''
    }

    // ════════════════════════════════════
    //  FASE 7: IMPLEMENT + RECONCILE
    // ════════════════════════════════════

    specDomain.analyzeEngine -> execution.dagExecutor 'tasks.md validado' {
      notes '''
        **Implement Phase**
        - DAG Executor despacha implement node via claude -p
        - Executa tasks em ordem de dependencia
        - Commit por task, PR ao final
      '''
    }

    execution.dagExecutor -> integration.githubOps 'Cria PR com implementacao' {
      notes '''
        **GitHub Integration**
        - Cria branch epic/<platform>/<NNN-slug>
        - PR com referencia ao epic e spec
      '''
    }

    execution.dagExecutor -> documentation.autoMarkers 'RECONCILE: atualiza Vision' {
      notes '''
        **Reconcile Phase**
        - Auto-update de Vision docs apos implementacao
        - vision-build.py re-exporta LikeC4 JSON
        - Popula AUTO markers com dados atualizados
        - Garante que docs refletem o estado real do codigo
      '''
    }

    // ════════════════════════════════════
    //  HUMAN GATE (decisoes 1-way-door)
    // ════════════════════════════════════

    execution.dagExecutor -> integration.telegramAdapter 'Human gate: solicita aprovacao' {
      notes '''
        **Human Gate**
        - DAG Executor pausa em nodes com gate=human ou 1-way-door
        - Grava estado pending_approval no SQLite
        - Notifica via Telegram (ask_choice com inline buttons)
        - Resume quando operador aprova (via Telegram ou CLI)
      '''
    }

    integration.telegramAdapter -> telegramBot 'Envia mensagem via Telegram Bot API'

    // ════════════════════════════════════
    //  OBSERVABILIDADE (passiva)
    // ════════════════════════════════════

    parallel {
      execution.dagExecutor -> observability.metricsCollector 'Trace DAG execution'
      intelligence.subagentJudgeModule -> observability.metricsCollector 'Trace review cycles'
      specDomain.specifyPhase -> observability.metricsCollector 'Trace spec generation'
    }

    observability.metricsCollector -> observability.dashboardWeb 'Metricas consolidadas' {
      notes '''
        **Dashboard de Observabilidade**
        - Duracao de pipelines por fase
        - Kanban de epics
        - Error rates e health status
        - Sentry captura stack traces e performance traces
      '''
    }
  }
}
