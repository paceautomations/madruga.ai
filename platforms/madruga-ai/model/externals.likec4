model {

  claudeApi = externalService 'Claude API' {
    technology 'Anthropic API (claude -p subprocess)'
    description 'LLM backend para geracao de specs, debate, decisoes, e implementacao. Invocado via claude -p subprocess pelo SpeckitBridge e DAG Executor'
  }

  telegramBot = externalService 'Telegram' {
    technology 'Telegram Bot API (aiogram, HTTPS outbound)'
    description 'Canal de notificacoes criticas via Telegram Bot: pipeline concluido, erros, decisoes que requerem atencao humana. Bidirecional (send + ask_choice com inline buttons)'
  }

  githubApi = externalService 'GitHub' {
    technology 'GitHub API (gh CLI)'
    description 'PRs, issues, code review. taskstoissues converte tasks.md em GitHub issues com dependencias'
  }

  likec4Cli = externalService 'LikeC4 CLI' {
    technology 'likec4 (npm)'
    description 'CLI para servir, buildar, e exportar modelos de arquitetura. Usado por vision-build.py e portal'
  }

  sentryCloud = externalService 'Sentry' {
    technology 'Sentry Cloud (free tier)'
    description 'Error tracking com stack traces, breadcrumbs, e performance traces. Auto-instrumenta FastAPI via sentry-sdk'
  }
}
