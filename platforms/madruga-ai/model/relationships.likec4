model {

  // ══════════════════════════════════════
  //  C4 CONTAINER RELATIONSHIPS
  // ══════════════════════════════════════

  // ── Architect interactions ──
  architect -> madrugaAi.portal 'Consulta documentacao' {
    technology 'HTTPS (browser)'
  }

  architect -> madrugaAi.speckitSkills 'Executa skills interativamente' {
    technology 'Claude Code CLI'
  }

  architect -> madrugaAi.platformCli 'Gerencia plataformas' {
    technology 'CLI (Python)'
  }

  architect -> madrugaAi.dashboard 'Consulta status e kanban de epics' {
    technology 'HTTPS (browser)'
  }

  // ── Daemon interactions ──
  daemon -> madrugaAi.runtimeDaemon 'Processo principal' {
    technology 'systemd / supervisord'
  }

  // ── Internal container relationships ──
  madrugaAi.runtimeDaemon -[sync]-> madrugaAi.dagExecutor 'Inicia execucao do DAG' {
    technology 'Python async'
  }

  madrugaAi.dagExecutor -[sync]-> madrugaAi.speckitSkills 'Le skills e compoe prompts (compose_skill_prompt)' {
    technology 'Filesystem read'
  }

  madrugaAi.dagExecutor -[sync]-> madrugaAi.memoryStore 'Le/escreve estado do pipeline' {
    technology 'SQLite (checkpoint por node)'
  }

  madrugaAi.dagExecutor -[sync]-> madrugaAi.subagentJudge 'Solicita review multi-perspectiva' {
    technology 'Claude Code Agent tool'
  }

  madrugaAi.runtimeDaemon -[sync]-> madrugaAi.memoryStore 'Persiste estado e metricas' {
    technology 'SQLite (aiosqlite)'
  }

  madrugaAi.dashboard -[sync]-> madrugaAi.memoryStore 'Le metricas, status, e kanban' {
    technology 'SQLite (read-only)'
  }

  madrugaAi.platformCli -[sync]-> madrugaAi.copierTemplates 'Scaffold e sync plataformas' {
    technology 'Copier Python API'
  }

  madrugaAi.visionBuild -[sync]-> madrugaAi.portal 'Popula AUTO markers no markdown' {
    technology 'Filesystem write'
  }

  // ── External system relationships ──
  madrugaAi.dagExecutor -[sync]-> claudeApi 'Despacha nodes via claude -p' {
    technology 'subprocess (claude -p)'
  }

  madrugaAi.subagentJudge -[sync]-> claudeApi 'Review via 4 subagents paralelos + 1 judge' {
    technology 'Claude Code Agent tool'
  }

  madrugaAi.runtimeDaemon -[async]-> telegramBot 'Notificacoes e decisoes' {
    technology 'Telegram Bot API (HTTPS outbound)'
  }

  madrugaAi.dagExecutor -[sync]-> githubApi 'Cria PRs via gh CLI' {
    technology 'gh CLI'
  }

  madrugaAi.visionBuild -[sync]-> likec4Cli 'Exporta JSON do modelo' {
    technology 'likec4 export json'
  }

  madrugaAi.portal -[sync]-> likec4Cli 'Build e serve diagramas' {
    technology 'LikeC4VitePlugin'
  }

  madrugaAi.runtimeDaemon -[async]-> sentryCloud 'Error tracking e performance traces' {
    technology 'sentry-sdk (HTTPS)'
  }

  // ── Storage relationships ──
  madrugaAi.dagExecutor -[sync]-> gitFs 'Le e escreve artefatos' {
    technology 'Filesystem (git)'
  }

  madrugaAi.platformCli -[sync]-> gitFs 'Scaffold e valida plataformas' {
    technology 'Filesystem (git)'
  }

  madrugaAi.visionBuild -[sync]-> gitFs 'Le JSON exportado, escreve markdown' {
    technology 'Filesystem (git)'
  }

  madrugaAi.runtimeDaemon -[sync]-> sqliteDb 'Estado operacional' {
    technology 'aiosqlite'
  }

  madrugaAi.dashboard -[sync]-> sqliteDb 'Consulta metricas e kanban' {
    technology 'SQLite read-only'
  }

  madrugaAi.dagExecutor -[sync]-> sqliteDb 'Checkpoint por node' {
    technology 'SQLite'
  }

  // ══════════════════════════════════════
  //  DDD CONTEXT MAP RELATIONSHIPS
  // ══════════════════════════════════════

  // ── Core-Core ──
  specDomain.specifyPhase -[customerSupplier]-> documentation.autoMarkers 'Customer-Supplier' {
    description 'Specification (customer) gera specs que Documentation (supplier) popula com dados do modelo via AUTO markers'
  }

  // ── Core-Supporting ──
  specDomain.specifyPhase -[customerSupplier]-> intelligence.subagentJudgeModule 'Customer-Supplier' {
    description 'Specification (customer) solicita review multi-perspectiva a Intelligence (supplier) via Subagent Judge (ADR-019)'
  }

  specDomain.planPhase -[customerSupplier]-> intelligence.decisionModule 'Customer-Supplier' {
    description 'Specification (customer) solicita classificacao de decisoes a Intelligence (supplier)'
  }

  execution.dagExecutor -[customerSupplier]-> specDomain.specifyPhase 'Customer-Supplier' {
    description 'Execution (customer) invoca fases de Specification (supplier) em sequencia via compose_skill_prompt'
  }

  execution.dagExecutor -[acl]-> integration.claudeClient 'ACL' {
    description 'DAG Executor usa ACL para isolar detalhes do Claude API (subprocess, retries) do executor'
  }

  // ── Supporting-Generic ──
  execution.dagExecutor -[acl]-> integration.claudeClient 'ACL (dispatch)' {
    description 'DAG Executor usa ACL para isolar detalhes do Claude API (subprocess, retries) do dispatch de nodes'
  }

  integration.githubOps -[conformist]-> githubApi 'Conformist' {
    description 'Integration se conforma ao formato de issues e PRs da GitHub API'
  }

  integration.telegramAdapter -[conformist]-> telegramBot 'Conformist' {
    description 'Integration se conforma ao protocolo da Telegram Bot API (sendMessage, InlineKeyboard, callback_query)'
  }

  integration.claudeClient -[conformist]-> claudeApi 'Conformist' {
    description 'Integration se conforma ao protocolo claude -p subprocess (stdin/stdout)'
  }

  integration.sentryAdapter -[conformist]-> sentryCloud 'Conformist' {
    description 'Integration se conforma ao protocolo Sentry SDK (DSN, events, traces)'
  }

  // ── Observability (Pub-Sub) ──
  execution.daemonProcess -[pubSub]-> observability.metricsCollector 'Pub-Sub'
  execution.dagExecutor -[pubSub]-> observability.metricsCollector 'Pub-Sub (executor)'
  execution.dagExecutor -[pubSub]-> observability.metricsCollector 'Pub-Sub'
  intelligence.subagentJudgeModule -[pubSub]-> observability.metricsCollector 'Pub-Sub'
  specDomain.specifyPhase -[pubSub]-> observability.metricsCollector 'Pub-Sub'

  // ── Documentation-Generic ──
  documentation.modelPipeline -[acl]-> likec4Cli 'ACL' {
    description 'Documentation usa ACL para isolar formato de export LikeC4 do modelo interno de artefatos'
  }
}
