model {

  madrugaAi = platform 'Madruga AI' {
    description 'Sistema de documentacao arquitetural e pipeline spec-to-code para plataformas digitais'

    portal = frontend 'Portal' {
      technology 'Astro + Starlight + LikeC4 React'
      description 'Portal de documentacao que auto-descobre plataformas, renderiza markdown e embeda diagramas LikeC4 interativos'
    }

    platformCli = api 'Platform CLI' {
      technology 'Python 3.12+ (platform.py)'
      description 'CLI para gestao de plataformas: new, lint, sync, register, status, import/export. Encapsula Copier e validacao estrutural'
    }

    visionBuild = worker 'Vision Build Pipeline' {
      technology 'Python 3.12+ (vision-build.py)'
      description 'Exporta LikeC4 JSON e popula tabelas markdown via AUTO markers em engineering docs'
    }

    speckitBridge = worker 'SpeckitBridge' {
      technology 'Python 3.12+'
      description 'Compositor que le skills e templates, monta prompts contextuais com constitution + memory, e executa as 7 fases do pipeline (specify, clarify, plan, tasks, implement, reconcile, analyze) via claude -p'
    }

    runtimeDaemon = worker 'Runtime Daemon' {
      technology 'Python 3.12+ asyncio + FastAPI :8040'
      description 'Daemon 24/7: executa DAG do pipeline, gerencia human gates, health endpoints, serve dashboard'
    }

    dagExecutor = worker 'DAG Executor' {
      technology 'Python 3.12+ (dag_runner.py)'
      description 'Le pipeline DAG de platform.yaml, resolve dependencias via topological sort, despacha nodes via claude -p, gerencia human gates (pause/resume via SQLite)'
    }

    orchestrator = worker 'Orchestrator' {
      technology 'Python 3.12+'
      description 'Slot-based scheduler que controla paralelismo de pipelines, gerencia filas e prioridades'
    }

    subagentJudge = worker 'Subagent Judge' {
      technology 'Python 3.12+ + Claude Code Agent tool'
      description 'Subagent Paralelo + Judge Pattern: 3 personas (Architecture Reviewer, Bug Hunter, Simplifier) + 1 juiz que filtra por Accuracy/Actionability/Severity (ADR-019). Output: BLOCKER/WARNING/NIT'
    }

    decisionSystem = worker 'Decision System' {
      technology 'Python 3.12+'
      description 'Classificador 1-way/2-way door para decisoes arquiteturais, com registro automatico de ADRs'
    }

    memoryStore = database 'State Store' {
      technology 'SQLite WAL (madruga.db)'
      description 'Persistencia: pipeline state, epics, decisions, memory, provenance, metricas de observabilidade'
    }

    dashboard = frontend 'Dashboard' {
      technology 'FastAPI + HTML :8040'
      description 'Dashboard de observabilidade e kanban de epics: pipeline status, metricas, health check, gestao visual de epics'
    }

    speckitSkills = worker 'SpecKit Skills' {
      technology '20 .claude/commands/ (Markdown)'
      description 'Skills do pipeline: 13 L1 (vision, adr, blueprint...) + 7 L2 (specify, plan, tasks, implement, verify, qa, reconcile) + utilities'
    }

    copierTemplates = worker 'Copier Templates' {
      technology 'Jinja2 + copier.yml'
      description 'Template Copier para scaffolding de novas plataformas com estrutura padrao (business/, engineering/, decisions/, epics/, model/)'
    }
  }
}
