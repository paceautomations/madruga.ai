views {

  // ══════════════════════════════════════
  //  STRUCTURAL VIEWS (o que existe)
  // ══════════════════════════════════════

  view index {
    title 'Fulano — System Landscape'
    description 'Visao geral da plataforma e sistemas externos'

    include agent, admin
    include fulano
    include evolutionApi, claudeSonnet, claudeHaiku
    include redis, supabaseFulano
  }

  view containers of fulano {
    title 'C4 L2 — Containers & Integrations'
    description 'Containers deployaveis, storage, sistemas externos e mapa completo de integracoes'

    include *
    include agent, admin
    include redis, supabaseFulano, bifrost, langfuse, infisical
    include evolutionApi, supabaseResenhai, claudeSonnet, claudeHaiku
  }

  view contextMap {
    title 'DDD Context Map'
    description 'Bounded contexts, relacoes DDD (ACL, Conformist, Customer-Supplier, Pub-Sub)'

    include channel, channel.*
    include conversation, conversation.*
    include safety, safety.*
    include operations, operations.*
    include observability, observability.*
    include agent, admin
    include evolutionApi, bifrost, claudeSonnet, claudeHaiku
    include redis, supabaseFulano, supabaseResenhai, langfuse
  }

  // ── Scoped Views (zoom por bounded context) ──

  view channelDetail of channel {
    title 'Channel — Ingestao e Entrega'
    description 'Bounded context Channel: recepcao, debounce, roteamento e entrega de mensagens'

    include *
    include evolutionApi, redis
  }

  view conversationDetail of conversation {
    title 'Conversation — Pipeline Core'
    description 'Bounded context Conversation (Core Domain): clientes, contexto, classificacao, agentes e avaliacao'

    include *
    include bifrost, supabaseFulano, supabaseResenhai
  }

  view safetyDetail of safety {
    title 'Safety — Guardrails'
    description 'Bounded context Safety: validacao de entrada e saida'

    include *
  }

  view operationsDetail of operations {
    title 'Operations — Handoff & Triggers'
    description 'Bounded context Operations: handoff humano e mensagens proativas'

    include *
    include fulano.fulanoAdmin, admin
    include supabaseFulano
    include channel.m11
  }

  // ══════════════════════════════════════
  //  FLUXO DE NEGOCIO (pipeline completo)
  // ══════════════════════════════════════

  dynamic view businessFlow {
    title 'Business Process — Pipeline Completo'
    description 'Todos os caminhos da plataforma Fulano: mensagem individual (1:1), grupo (@mention), handoff humano, triggers proativos. 14 modulos, 5 paths de roteamento, 3 decision points.'

    autoLayout TopBottom

    // ════════════════════════════════════
    //  FASE 1: ENTRADA (Channel Inbound)
    // ════════════════════════════════════

    // Step 1 — Mensagem chega
    agent -> channel.m1 'Mensagem WhatsApp' {
      notes '''
        **Entrada do sistema**
        - Webhook POST do Evolution API
        - Tipos: texto, audio, imagem, video, documento, sticker, contato, localizacao
        - Validacao HMAC-SHA256 obrigatoria
      '''
    }

    // Step 2 — Normalizacao + Buffer
    channel.m1 -> channel.m2 'InboundMessage normalizado' {
      notes '''
        **Debounce (3 segundos)**
        - Agrupa mensagens rapidas do mesmo usuario
        - Redis Lua script atomico
        - Evita processar cada msg individualmente
      '''
    }

    // Step 3 — Roteamento
    channel.m2 -> channel.m3 'BufferedBatch' {
      notes '''
        **Smart Router — Decision Point #1**
        5 caminhos possiveis:
        1. SUPPORT → pipeline completo (1:1)
        2. GROUP_RESPOND → pipeline com contexto de grupo
        3. GROUP_SAVE_ONLY → salva sem LLM (zero custo)
        4. HANDOFF_ATIVO → bypass IA, direto para humano
        5. IGNORE → duplicata ou evento interno
      '''
    }

    // ════════════════════════════════════
    //  FASE 2: DECISION POINT #1 (Router)
    // ════════════════════════════════════

    parallel {
      // Path A: Pipeline principal (SUPPORT + GROUP)
      channel.m3 -> conversation.m4 'SUPPORT / GROUP_RESPOND' {
        notes '''
          **Caminho principal**
          - Individual (1:1): pipeline completo
          - Grupo (@mention): mesmo pipeline, contexto de grupo
        '''
      }

      // Path B: Handoff ativo (bypass IA)
      channel.m3 -> operations.m12 'HANDOFF_ATIVO' {
        notes '''
          **Bypass completo da IA**
          Conversa ja escalada para humano.
          Mensagem vai direto para o atendente.
        '''
      }
    }

    // ════════════════════════════════════
    //  FASE 3: PIPELINE CORE (IA)
    // ════════════════════════════════════

    // Step 4 — Customer
    conversation.m4 -> conversation.m5 'CustomerContext' {
      notes '''
        **Gestao de Cliente**
        - Busca/cria customer no Supabase
        - Carrega perfil + preferencias + historico
        - Persiste mensagens recebidas
      '''
    }

    // Step 5 — Contexto
    conversation.m5 -> safety.m6 'AgentContext (3 camadas)' {
      notes '''
        **Montagem de Contexto**
        1. Perfil do cliente (longo prazo)
        2. Estado da conversa (sessao)
        3. Working memory (ultimas interacoes)
        + RAG results quando disponivel
      '''
    }

    // Step 6 — Guardrail Entrada
    safety.m6 -> conversation.m7 'Mensagem sanitizada' {
      notes '''
        **Guardrail de Entrada — Decision Point #2**
        - PII: detecta CPF, telefone, email
        - Toxicidade: filtra conteudo ofensivo
        - Injection: bloqueia prompt injection
        - Resultado: PASS | BLOCK (msg padrao) | FLAG (alerta)
      '''
    }

    // Step 7 — Classificacao
    conversation.m7 -> conversation.m8 'IntentClassification' {
      notes '''
        **Classificador de Intent**
        - Claude Haiku (rapido, barato)
        - Determina: intent + confidence (0-1)
        - Se confidence < 0.7 → fallback "general"
        - Habilita tools especificos por intent
      '''
    }

    // Step 8 — Agente IA
    conversation.m8 -> conversation.m9 'AgentResponse' {
      notes '''
        **Core IA — Agente Sonnet**
        - Claude Sonnet com tools habilitados
        - Tools: get_ranking, get_stats, get_player, handoff
        - ~2-5 LLM calls por conversa ativa
        - Gera: resposta + reasoning + tool calls
      '''
    }

    // ════════════════════════════════════
    //  FASE 4: DECISION POINT #3 (Quality)
    // ════════════════════════════════════

    parallel {
      // Caminho feliz: APPROVE
      conversation.m9 -> safety.m10 'APPROVE (score > 0.8)' {
        notes '''
          **Aprovado pelo Avaliador**
          - Score qualidade > 0.8
          - Formata para WhatsApp
          - Markdown, emojis, limites de caracteres
        '''
      }

      // Escalacao: ESCALATE
      conversation.m9 -> operations.m12 'ESCALATE (score < 0.5)' {
        notes '''
          **Escalacao para Humano**
          - Confidence baixa (< 0.5)
          - Topico critico detectado
          - Request explicito do usuario
          - RETRY se 0.5-0.8 (max 2x antes de escalar)
        '''
      }
    }

    // ════════════════════════════════════
    //  FASE 5: SAIDA (Channel Outbound)
    // ════════════════════════════════════

    // Entrega da resposta IA
    safety.m10 -> channel.m11 'Payload formatado' {
      notes '''
        **Entrega via Evolution API**
        - POST /message/sendText/{instance}
        - Retry 3x com backoff (1s, 4s, 16s)
        - Persiste mensagem role=assistant
        - Atualiza metricas de conversa
      '''
    }

    // ════════════════════════════════════
    //  FASE 6: HANDOFF HUMANO
    // ════════════════════════════════════

    operations.m12 -> fulano.fulanoAdmin 'Notifica atendente (Socket.io)' {
      notes '''
        **State Machine do Handoff**
        AGENT_ACTIVE → PENDING (5min timeout)
        → ASSIGNED (atendente aceita)
        → HUMAN_ACTIVE (30min inatividade)
        → COMPLETED → AGENT_ACTIVE
      '''
    }

    admin -> operations.m12 'Aceita handoff (PENDING → ASSIGNED)'
    operations.m12 -> channel.m11 'Humano responde via bot'

    // ════════════════════════════════════
    //  FASE 7: TRIGGERS PROATIVOS
    // ════════════════════════════════════

    supabaseFulano -> operations.m13 'PG LISTEN/NOTIFY' {
      notes '''
        **Mensagem Proativa (sem LLM)**
        - Eventos: INSERT em games, group_members
        - Match contra trigger rules do tenant
        - Cooldown por cliente (anti-spam)
        - Render template Jinja2
      '''
    }

    operations.m13 -> channel.m11 'Mensagem proativa renderizada'

    // Entrega final (todos os paths convergem aqui)
    channel.m11 -> evolutionApi 'POST sendText/{instance}' {
      notes '''
        **Ponto de convergencia**
        Todos os caminhos terminam aqui:
        - Resposta IA (pipeline principal)
        - Resposta humana (handoff)
        - Mensagem proativa (trigger)
      '''
    }

    // ════════════════════════════════════
    //  FASE 8: OBSERVABILIDADE (passiva)
    // ════════════════════════════════════

    parallel {
      channel.m1 -> observability.m14 'Trace recepcao'
      conversation.m5 -> observability.m14 'Trace contexto'
      conversation.m8 -> observability.m14 'Trace agente + tokens'
      conversation.m9 -> observability.m14 'Trace eval scores'
      operations.m12 -> observability.m14 'Trace handoff events'
      operations.m13 -> observability.m14 'Trace trigger events'
    }

    observability.m14 -> langfuse 'Traces + scores (fire-and-forget)' {
      notes '''
        **Observabilidade — LangFuse + DeepEval + Promptfoo**
        - Traces com spans por modulo (M1-M13)
        - trace_id = conversation_id
        - Scores de eval (online + offline)
        - Fire-and-forget: falha nao bloqueia pipeline
        - Prompt versions como source of truth
      '''
    }
  }
}
