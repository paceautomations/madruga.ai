model {

  redis = cache 'Redis' {
    #critical
    technology 'Redis 7'
    description 'Componente critico. Job queue (ARQ), debounce buffers (Lua atomico), cache de sessao, PubSub. Particionamento por prefixo: arq:, buf:, cache:, ps:. AOF enabled para crash recovery. Sem fallback — healthcheck + restart automatico.'
    link ../decisions/ADR-003-redis-streams.md 'ADR-003: Redis Streams'
    metadata {
      port '6379'
      partitions 'arq: (queue), buf: (debounce), cache: (lookup), ps: (PubSub)'
    }
  }

  supabaseFulano = database 'Supabase Fulano' {
    #critical
    technology 'PostgreSQL 15 + pgvector'
    description 'Source of truth do sistema. Armazena conversas, mensagens, clientes, prompts versionados, trigger rules, eval scores. pgvector para embeddings (1536 dims, HNSW index). RLS com tenant_id para isolamento multi-tenant. LISTEN/NOTIFY para realtime events.'
    link ../decisions/ADR-011-pool-rls-multi-tenant.md 'ADR-011: RLS Multi-Tenant'
    link ../decisions/ADR-013-pgvector-tenant-knowledge.md 'ADR-013: pgvector'
    metadata {
      port '5432'
      channels 'games (INSERT, UPDATE), group_members (INSERT, DELETE)'
    }
  }

  bifrost = proxy 'Bifrost' {
    technology 'Go (Bifrost)'
    description 'Proxy LLM com interface OpenAI-compatible (/v1/chat/completions). Rate limiting por tenant configuravel, fallback chain (Sonnet -> Haiku -> resposta generica), cost tracking agregado por modelo e tenant. Circuit breaker integrado.'
    link ../decisions/ADR-002-bifrost-llm-proxy.md 'ADR-002: Bifrost LLM Proxy'
    metadata {
      port '8050'
      fallbackChain 'Claude Sonnet -> Claude Haiku -> Resposta generica'
    }
  }

  langfuse = externalService 'LangFuse' {
    technology 'LangFuse v3 self-hosted'
    description 'Observabilidade completa: traces com spans por modulo, scores de eval (online + offline), prompt versions como source of truth para templates em producao. trace_id = conversation_id para correlacao direta. Fire-and-forget (falha nao bloqueia fluxo).'
    link ../decisions/ADR-007-langfuse-observability.md 'ADR-007: LangFuse'
    metadata {
      port '3001'
    }
  }

  infisical = externalService 'Infisical' {
    technology 'Infisical Cloud'
    description 'Secrets manager. Tenant credentials, API keys, webhook secrets. Cache em memoria com TTL 5min. Fallback: env vars para degradacao graciosa.'
    link ../decisions/ADR-017-secrets-management.md 'ADR-017: Secrets'
  }
}
