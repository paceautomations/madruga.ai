# Telegram Bot for gate notifications (optional)
# 1. Message @BotFather on Telegram, /newbot, follow prompts
# 2. Copy the token below
MADRUGA_TELEGRAM_BOT_TOKEN=
# 3. Start a chat with your bot, send any message
# 4. Visit https://api.telegram.org/bot<TOKEN>/getUpdates
# 5. Copy chat.id from the response
MADRUGA_TELEGRAM_CHAT_ID=

# Easter pipeline mode: manual (default), interactive, auto
# MADRUGA_MODE=manual

# Sentry error tracking (optional)
# MADRUGA_SENTRY_DSN=

# ntfy.sh fallback notifications (optional)
# MADRUGA_NTFY_TOPIC=

# --- ProsaUAI Conversation Core (epic 005) ---

# PostgreSQL connection string (required for conversation pipeline)
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://prosauai:prosauai@localhost:5432/prosauai

# OpenAI API key for LLM generation via pydantic-ai (required)
OPENAI_API_KEY=

# Max concurrent LLM calls (default: 10)
# LLM_SEMAPHORE_SIZE=10

# Hours of inactivity before auto-closing a conversation (default: 24, range: 1-72)
# CONVERSATION_INACTIVITY_TIMEOUT_HOURS=24

# Max messages in the sliding context window (default: 10)
# CONTEXT_WINDOW_SIZE=10

# Max tokens budget for context window (default: 8000)
# MAX_CONTEXT_TOKENS=8000
