{
  "name": "portal",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "prestatus": "cd .. && python3 .specify/scripts/platform_cli.py status --all --json --output portal/src/data/pipeline-status.json 2>/dev/null || echo '{\"generated_at\":\"\",\"platforms\":[]}' > portal/src/data/pipeline-status.json",
    "predev": "npm run prestatus && cd .. && python3 .specify/scripts/validate_frontmatter.py",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "npm run prestatus",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:component": "vitest run --dir src/test/unit",
    "test:visual": "playwright test --config=playwright.config.ts src/test/visual",
    "test:e2e": "playwright test --config=playwright.config.ts src/test/e2e",
    "size": "size-limit"
  },
  "dependencies": {
    "@astrojs/react": "^5.0.4",
    "@astrojs/starlight": "^0.38.4",
    "@xyflow/react": "^12.10.2",
    "astro": "^6.1.9",
    "astro-mermaid": "^2.0.1",
    "elkjs": "^0.11.1",
    "js-yaml": "^4.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "sharp": "^0.34.2",
    "svg-pan-zoom": "^3.6.2"
  },
  "overrides": {
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.0.0",
    "@playwright/test": "^1.48.0",
    "@size-limit/preset-app": "^11.0.0",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jest-image-snapshot": "^6.0.0",
    "jsdom": "^25.0.0",
    "size-limit": "^11.0.0",
    "vitest": "^2.0.0"
  }
}
