---
import { discoverPlatforms } from '../lib/platforms.mjs';

const platforms = discoverPlatforms();
const defaultPlatform = platforms[0]?.name || '';

// Backwards-compat redirect: /control-panel/?platform=X → /{platform}/control-panel/
const requested = Astro.url.searchParams.get('platform') || defaultPlatform;
const validPlatform = platforms.find((p: any) => p.name === requested) ? requested : defaultPlatform;

return Astro.redirect(`/${validPlatform}/control-panel/`, 301);
---
