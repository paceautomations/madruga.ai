---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import PipelineDAG from '../../components/dashboard/PipelineDAG.tsx';
import { discoverPlatforms } from '../../lib/platforms.mjs';
import { NODE_LABELS, NODE_ROUTE_OVERRIDES, resolveNodeHref } from '../../lib/constants';

export function getStaticPaths() {
  return discoverPlatforms().map((p) => ({
    params: { platform: p.name },
    props: { manifest: p },
  }));
}

const { manifest } = Astro.props;
const platformName = manifest.name;

// ── Load data ──
let statusData = { generated_at: '', platforms: [] as any[] };
try {
  statusData = await import('../../data/pipeline-status.json');
} catch { /* not generated yet */ }

const platform = (statusData.platforms || []).find((p: any) => p.id === platformName);
const hasData = !!platform;

// ── L1: Group by layer ──
const LAYERS = [
  { id: 'business', label: 'Business', color: '#3b82f6' },
  { id: 'research', label: 'Research', color: '#a78bfa' },
  { id: 'engineering', label: 'Engineering', color: '#10b981' },
  { id: 'planning', label: 'Planning', color: '#f59e0b' },
];

const GATE_ICON: Record<string, string> = {
  'human': '👤', 'auto': '⚡', '1-way-door': '🚪', 'auto-escalate': '⚡↑',
};

function groupByLayer(nodes: any[]) {
  return LAYERS.map(layer => ({
    ...layer,
    nodes: nodes.filter((n: any) => n.layer === layer.id),
    done: nodes.filter((n: any) => n.layer === layer.id && n.status === 'done').length,
    total: nodes.filter((n: any) => n.layer === layer.id).length,
  }));
}

// ── Next step ──
function findNextStep(nodes: any[]) {
  const doneIds = new Set(nodes.filter((n: any) => n.status === 'done').map((n: any) => n.id));
  for (const n of nodes) {
    if (n.status !== 'done' && n.status !== 'skipped') {
      const depsReady = (n.depends || []).every((d: string) => doneIds.has(d));
      if (depsReady) return n;
    }
  }
  return null;
}

// ── L2: Kanban with 5 phase groups ──
const PHASES = [
  { id: 'backlog', label: 'Backlog', stages: [] as string[] },
  { id: 'specifying', label: 'Specifying', stages: ['epic-context', 'specify', 'clarify'] },
  { id: 'planning', label: 'Planning', stages: ['plan', 'tasks', 'analyze'] },
  { id: 'building', label: 'Building', stages: ['implement', 'analyze-post', 'verify'] },
  { id: 'shipping', label: 'Shipping', stages: ['qa', 'reconcile'] },
  { id: 'shipped', label: 'Shipped', stages: [] as string[] },
];

const ALL_L2_STAGES = ['epic-context','specify','clarify','plan','tasks','analyze','implement','analyze-post','verify','qa','reconcile'];

function getEpicPhase(epic: any): { phaseId: string; subStage: string } {
  // Check epic-level status first (from DB)
  if (epic.status === 'shipped') return { phaseId: 'shipped', subStage: '' };
  if (!epic.nodes || epic.nodes.length === 0) return { phaseId: 'backlog', subStage: '' };
  const doneIds = new Set(epic.nodes.filter((n: any) => n.status === 'done').map((n: any) => n.id));
  if (doneIds.size >= ALL_L2_STAGES.length) return { phaseId: 'shipped', subStage: '' };
  if (doneIds.size === 0) return { phaseId: 'backlog', subStage: '' };
  // Find last done stage
  let lastDoneIdx = -1;
  for (let i = ALL_L2_STAGES.length - 1; i >= 0; i--) {
    if (doneIds.has(ALL_L2_STAGES[i])) { lastDoneIdx = i; break; }
  }
  // Next stage
  const nextStage = lastDoneIdx < ALL_L2_STAGES.length - 1 ? ALL_L2_STAGES[lastDoneIdx + 1] : ALL_L2_STAGES[lastDoneIdx];
  // Find which phase this stage belongs to
  for (const phase of PHASES) {
    if (phase.stages.includes(nextStage)) return { phaseId: phase.id, subStage: nextStage };
  }
  return { phaseId: 'backlog', subStage: '' };
}

function buildKanban(epics: any[]) {
  const columns: Record<string, any[]> = {};
  for (const p of PHASES) columns[p.id] = [];
  for (const epic of epics) {
    const { phaseId, subStage } = getEpicPhase(epic);
    columns[phaseId]?.push({ ...epic, subStage });
  }
  return columns;
}

const layers = hasData ? groupByLayer(platform.l1.nodes) : [];
const staleNodes = hasData ? platform.l1.nodes.filter((n: any) => n.status === 'stale') : [];
const nextStep = hasData ? findNextStep(platform.l1.nodes) : null;
const kanban = hasData ? buildKanban(platform.l2.epics) : {};
const totalEpics = hasData ? platform.l2.epics.length : 0;
const shippedEpics = hasData ? (kanban['shipped']?.length || 0) : 0;
const activeEpics = hasData ? totalEpics - (kanban['backlog']?.length || 0) - shippedEpics : 0;
---

<StarlightPage frontmatter={{ title: `Dashboard`, tableOfContents: false }}>

  {!hasData ? (
    <div class="empty-state">
      <p>Sem dados de pipeline. Execute <code>python3 .specify/scripts/platform.py status --all --json</code></p>
    </div>
  ) : (
    <>
      {/* ── Hero: Stats + Next Step ── */}
      <section class="hero">
        <div class="stats-row">
          <div class="stat">
            <span class="stat-value">{Math.round(platform.l1.progress_pct)}<span class="stat-unit">%</span></span>
            <span class="stat-label">L1 Completo</span>
          </div>
          <div class="stat">
            <span class="stat-value">{totalEpics}</span>
            <span class="stat-label">Epics</span>
          </div>
          <div class="stat">
            <span class="stat-value">{activeEpics}</span>
            <span class="stat-label">Em progresso</span>
          </div>
          <div class="stat">
            <span class="stat-value">{shippedEpics}</span>
            <span class="stat-label">Shipped</span>
          </div>
        </div>

        {nextStep && (
          <div class="next-step">
            <span class="next-label">Próximo passo</span>
            <code class="next-command">/{nextStep.id.replace(/-/g, '-')} {platformName}</code>
            <span class="next-desc">{NODE_LABELS[nextStep.id] || nextStep.id} · {nextStep.gate} gate</span>
          </div>
        )}
        {!nextStep && platform.l1.progress_pct >= 100 && (
          <div class="next-step done-step">
            <span class="next-label">L1 completo — pronto para epics</span>
          </div>
        )}
      </section>

      {/* ── Stale Alert ── */}
      {staleNodes.length > 0 && (
        <div class="stale-alert" role="alert">
          <span class="stale-icon">&#9888;</span>
          <div class="stale-content">
            <strong>{staleNodes.length} artefato(s) desatualizado(s)</strong> — dependencias mudaram apos a geracao.
            <span class="stale-commands">Re-execute: {staleNodes.map((n: any) => `/${n.id}`).join(', ')}</span>
          </div>
        </div>
      )}

      {/* ── Section 1: L1 Progress ── */}
      <section class="section">
        <div class="section-header">
          <h2>Fundação da Plataforma</h2>
          <span class="section-meta">{platform.l1.done}/{platform.l1.total} nós</span>
        </div>

        <div class="progress-bar-container" role="progressbar" aria-valuenow={platform.l1.progress_pct} aria-valuemin="0" aria-valuemax="100">
          <div class="progress-bar-track">
            <div class="progress-bar-fill" style={`width: ${platform.l1.progress_pct}%`}></div>
          </div>
        </div>

        <div class="layer-grid">
          {layers.map((layer) => (
            <div class={`layer-card ${layer.done === layer.total ? 'layer-complete' : ''}`} style={`--layer-color: ${layer.color}`}>
              <div class="layer-header">
                <h3>{layer.label}</h3>
                <span class="layer-count">{layer.done}/{layer.total}</span>
              </div>
              <div class="layer-nodes">
                {layer.nodes.map((n: any) => {
                  const href = n.status === 'done' && n.outputs?.length
                    ? resolveNodeHref(platformName, n.id, n.outputs[0])
                    : undefined;
                  return (
                    <a href={href} class={`node-row status-${n.status}`} title={`${n.id}: ${n.status} (${n.gate})`}>
                      <span class="node-icon" aria-label={n.status}>
                        {n.status === 'done' ? '✓' : n.status === 'pending' ? '○' : n.status === 'blocked' ? '✗' : n.status === 'stale' ? '⚠' : '–'}
                      </span>
                      <span class="node-name">{NODE_LABELS[n.id] || n.id}</span>
                      {n.optional && <span class="node-badge opt">opt</span>}
                      <span class="node-gate">{GATE_ICON[n.gate] || ''}</span>
                    </a>
                  );
                })}
              </div>
            </div>
          ))}
        </div>
      </section>

      {/* ── Section 2: L2 Kanban ── */}
      <section class="section">
        <div class="section-header">
          <h2>Epics</h2>
          <span class="section-meta">{totalEpics} epics · {activeEpics} ativos</span>
        </div>

        <div class="kanban-board" role="region" aria-label="Kanban de epics">
          {PHASES.map((phase) => {
            const cards = kanban[phase.id] || [];
            return (
              <div class={`kanban-col ${phase.id === 'shipped' ? 'col-shipped' : ''}`} role="group" aria-label={`${phase.label}: ${cards.length} epics`}>
                <div class="col-header">
                  <span class="col-title">{phase.label}</span>
                  {cards.length > 0 && <span class="col-count">{cards.length}</span>}
                </div>
                <div class="col-body">
                  {cards.length === 0 && (
                    <div class="col-empty"></div>
                  )}
                  {cards.map((epic: any) => (
                    <a href={`/${platformName}/epics/${epic.id}/pitch/`} class="epic-card" role="article" aria-label={`Epic ${epic.id}: ${epic.title}`}>
                      <div class="card-top">
                        <span class="card-id">{epic.id.split('-')[0]}</span>
                        {epic.subStage && <span class="card-stage">{epic.subStage}</span>}
                      </div>
                      <span class="card-title">{epic.title}</span>
                      {epic.done > 0 && (
                        <div class="card-progress">
                          <div class="card-bar" role="progressbar" aria-valuenow={epic.progress_pct}>
                            <div class="card-fill" style={`width: ${epic.progress_pct}%`}></div>
                          </div>
                          <span class="card-pct">{epic.done}/{epic.total}</span>
                        </div>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </section>

      {/* ── Section 3: DAG (collapsed by default) ── */}
      <section class="section">
        <details class="dag-details">
          <summary class="dag-summary">
            <h2>Pipeline DAG</h2>
            <span class="section-meta">Visualização interativa de dependências</span>
          </summary>
          <div class="dag-container">
            <PipelineDAG client:visible platforms={[platform]} />
          </div>
        </details>
      </section>

      <p class="footer-meta">Atualizado em {statusData.generated_at ? new Date(statusData.generated_at).toLocaleString('pt-BR') : '—'}</p>
    </>
  )}
</StarlightPage>

<style>
  /* ── Tokens ── */
  :root {
    --d-green: #22c55e;
    --d-amber: #f59e0b;
    --d-red: #ef4444;
    --d-gray: #6b7280;
    --d-orange: #f97316;
    --d-border: var(--sl-color-gray-5);
    --d-card: var(--sl-color-gray-7, #111);
    --d-surface: var(--sl-color-gray-6, #181818);
    --d-text: var(--sl-color-white);
    --d-text2: var(--sl-color-gray-2);
    --d-text3: var(--sl-color-gray-3);
    --d-text4: var(--sl-color-gray-4);
    --d-r: 6px;
  }

  .empty-state { text-align: center; padding: 3rem; color: var(--d-text3); }

  /* ═══ 1. HERO — stats baseline-aligned ═══ */
  .hero {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--d-border);
    flex-wrap: wrap;
  }

  .stats-row {
    display: flex;
    align-items: baseline;  /* KEY: baseline alignment */
    gap: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.2rem;
    border-right: 1px solid var(--d-border);
  }
  .stat:first-child { padding-left: 0; }
  .stat:last-child { border-right: none; padding-right: 0; }

  .stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--d-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
    height: 1.6rem;          /* fixed height for baseline alignment */
    display: flex;
    align-items: baseline;
  }

  .stat-unit {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--d-text3);
  }

  .stat-label {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-text4);
    margin-top: 0.3rem;
    white-space: nowrap;
  }

  .next-step {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    background: var(--d-surface);
    border: 1px solid var(--d-border);
    border-radius: var(--d-r);
  }

  .next-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-green);
    font-weight: 700;
  }

  .next-command {
    font-size: 0.78rem;
    padding: 0.12rem 0.4rem;
    background: var(--d-card);
    border-radius: 4px;
    color: var(--d-text);
    font-weight: 500;
  }

  .next-desc {
    font-size: 0.68rem;
    color: var(--d-text3);
  }

  .done-step .next-label { color: var(--d-green); }

  /* ═══ Sections ═══ */
  .section { margin-bottom: 2rem; }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-text3);
  }

  .section-meta {
    font-size: 0.68rem;
    color: var(--d-text4);
  }

  /* ═══ Progress bar ═══ */
  .progress-bar-container { margin-bottom: 0.9rem; }

  .progress-bar-track {
    background: var(--d-border);
    border-radius: 2px;
    height: 3px;
    overflow: hidden;
  }

  .progress-bar-fill {
    background: var(--d-green);
    height: 100%;
    border-radius: 2px;
  }

  /* ═══ 2. LAYER CARDS — equal height via stretch ═══ */
  .layer-grid {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;  /* all children same height */
  }

  @media (max-width: 900px) { .layer-grid { flex-wrap: wrap; } .layer-card { flex-basis: calc(50% - 0.25rem); } }
  @media (max-width: 550px) { .layer-card { flex-basis: 100%; } }

  .layer-card {
    flex: 1;
    margin: 0 !important;  /* override Starlight's * + * margin */
    border: 1px solid var(--d-border);
    border-left: 3px solid var(--layer-color);
    border-radius: var(--d-r);
    padding: 0.6rem 0.65rem;
    background: var(--d-card);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .layer-card:hover { border-color: var(--layer-color); }
  .layer-complete { background: color-mix(in srgb, var(--layer-color) 4%, var(--d-card)); }

  .layer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.4rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--d-border);
  }

  .layer-header h3 {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--layer-color);
  }

  .layer-count {
    font-size: 0.65rem;
    color: var(--d-text4);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  .layer-nodes { flex: 1; margin: 0 !important; } /* fills remaining card height, override Starlight */

  .node-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.25rem;
    border-radius: 3px;
    font-size: 0.78rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  a.node-row:hover { background: var(--d-surface); }
  .node-row:focus-visible { outline: 2px solid var(--sl-color-accent); outline-offset: 1px; }

  .node-icon { width: 14px; text-align: center; font-weight: 700; font-size: 0.7rem; flex-shrink: 0; }
  .status-done .node-icon { color: var(--d-green); }
  .status-pending .node-icon { color: var(--d-amber); }
  .status-blocked .node-icon { color: var(--d-red); }
  .status-stale .node-icon { color: var(--d-orange); }
  .status-skipped .node-icon { color: var(--d-gray); }

  .node-name { flex: 1; color: var(--d-text2); }
  .status-done .node-name { color: var(--d-text); }
  .status-skipped .node-name { text-decoration: line-through; color: var(--d-text4); }

  .node-badge {
    font-size: 0.5rem;
    padding: 0.05rem 0.25rem;
    border-radius: 3px;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--d-surface);
    color: var(--d-text4);
  }

  .node-gate { font-size: 0.6rem; flex-shrink: 0; opacity: 0.7; }

  .legend {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--d-text4);
  }
  .legend-item { display: flex; align-items: center; gap: 0.25rem; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.status-done { background: var(--d-green); }
  .dot.status-pending { background: var(--d-amber); }
  .dot.status-blocked { background: var(--d-red); }
  .dot.status-skipped { background: var(--d-gray); }
  .dot.status-stale { background: var(--d-orange); }

  /* ═══ 3. KANBAN — equal-height columns ═══ */
  .kanban-board {
    display: flex;
    gap: 0.4rem;
    align-items: stretch;  /* all columns same height */
  }

  @media (max-width: 900px) { .kanban-board { flex-wrap: wrap; } .kanban-col { flex-basis: calc(33% - 0.3rem); } }
  @media (max-width: 550px) { .kanban-col { flex-basis: calc(50% - 0.2rem); } }

  .kanban-col {
    flex: 1;
    margin: 0 !important;  /* override Starlight's * + * margin */
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .col-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3rem 0.45rem;
    margin: 0 !important;  /* override Starlight */
    background: var(--d-surface);
    border-radius: var(--d-r) var(--d-r) 0 0;
    border: 1px solid var(--d-border);
    border-bottom: none;
  }

  .col-title {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--d-text4);
  }

  .col-count {
    font-size: 0.55rem;
    background: var(--d-text3);
    color: var(--sl-color-black);
    border-radius: 8px;
    padding: 0.05rem 0.3rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    min-width: 14px;
    text-align: center;
    line-height: 1.3;
  }

  .col-body {
    flex: 1;
    margin: 0 !important;  /* override Starlight */
    padding: 0.3rem;
    background: var(--d-card);
    border: 1px solid var(--d-border);
    border-radius: 0 0 var(--d-r) var(--d-r);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .epic-card {
    display: block;
    padding: 0.45rem 0.5rem;
    background: var(--d-surface);
    border: 1px solid var(--d-border);
    border-radius: 5px;
    text-decoration: none;
    color: var(--d-text);
    transition: border-color 0.15s, transform 0.1s;
  }

  .epic-card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-1px);
  }

  .epic-card:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 1px;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.1rem;
  }

  .card-id {
    font-size: 0.6rem;
    color: var(--d-text4);
    font-weight: 700;
    font-family: var(--sl-font-mono, monospace);
  }

  .card-stage {
    font-size: 0.5rem;
    padding: 0.05rem 0.25rem;
    border-radius: 3px;
    background: var(--d-card);
    color: var(--d-text4);
    text-transform: uppercase;
    font-weight: 700;
  }

  .card-title {
    display: block;
    font-size: 0.72rem;
    line-height: 1.3;
    color: var(--d-text2);
  }

  .card-progress {
    margin-top: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .card-bar { flex: 1; height: 2px; background: var(--d-border); border-radius: 1px; overflow: hidden; }
  .card-fill { height: 100%; background: var(--d-green); border-radius: 1px; }
  .card-pct { font-size: 0.55rem; color: var(--d-text4); font-variant-numeric: tabular-nums; }

  .col-shipped .epic-card {
    border-left: 2px solid var(--d-green);
    opacity: 0.65;
  }

  .col-shipped .epic-card:hover {
    opacity: 0.9;
  }

  /* ═══ DAG ═══ */
  .dag-details {
    border: 1px solid var(--d-border);
    border-radius: var(--d-r);
    overflow: hidden;
  }

  .dag-summary {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    cursor: pointer;
    background: var(--d-surface);
    user-select: none;
