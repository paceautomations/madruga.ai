---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import ChangesTab from '../../components/changes/ChangesTab.tsx';
import DashboardCharts from '../../components/dashboard/DashboardCharts.tsx';
import ExecutionTab from '../../components/dashboard/ExecutionTab.tsx';
import ObservabilityDashboard from '../../components/observability/ObservabilityDashboard.tsx';
import { discoverPlatforms, loadStatusData } from '../../lib/platforms.mjs';
import { loadScreenFlow } from '../../lib/screen-flow';

export function getStaticPaths() {
  const platforms = discoverPlatforms();
  const allPlatformIds = platforms.map((p) => p.name);
  return platforms.map((p) => ({
    params: { platform: p.name },
    props: { allPlatformIds },
  }));
}

const { platform } = Astro.params;
const { allPlatformIds } = Astro.props;
const statusData = loadStatusData() || { generated_at: '', platforms: [] };
const selectedId = platform || allPlatformIds[0] || '';

// Derive GitHub repo URL from platform manifest
const platforms = discoverPlatforms();
const currentPlatform = platforms.find((p) => p.name === selectedId);
const repoOrg = currentPlatform?.repo?.org;
const repoName = currentPlatform?.repo?.name;
const repoUrl = repoOrg && repoName ? `https://github.com/${repoOrg}/${repoName}` : undefined;

// Screen-flow capture coverage (epic 027 — process improvement #10).
// Emits a small card BEFORE the tab bar when `screen_flow.enabled: true`.
let screenFlowCoverage: {
  total: number;
  pending: number;
  captured: number;
  failed: number;
  percent: number;
} | null = null;
if (currentPlatform?.screen_flow?.enabled) {
  try {
    const flow = loadScreenFlow(selectedId);
    if (flow) {
      const total = flow.screens.length;
      const captured = flow.screens.filter((s: any) => s.status === 'captured').length;
      const pending = flow.screens.filter((s: any) => s.status === 'pending').length;
      const failed = flow.screens.filter((s: any) => s.status === 'failed').length;
      screenFlowCoverage = {
        total,
        captured,
        pending,
        failed,
        percent: total > 0 ? Math.round((captured / total) * 100) : 0,
      };
    }
  } catch {
    // YAML missing or invalid — leave coverage null (card will not render)
  }
}
---

<StarlightPage frontmatter={{ title: `Control Panel`, tableOfContents: false }}>

  {screenFlowCoverage && (
    <a class="cp-coverage-card" href={`/${selectedId}/screens/`} aria-label="Ver canvas de telas">
      <div class="cp-coverage-title">
        Screen Capture Coverage
        <span class="cp-coverage-pct">{screenFlowCoverage.percent}%</span>
      </div>
      <div class="cp-coverage-bar" role="progressbar" aria-valuenow={screenFlowCoverage.percent} aria-valuemin="0" aria-valuemax="100">
        <div class="cp-coverage-fill" style={`width: ${screenFlowCoverage.percent}%`}></div>
      </div>
      <div class="cp-coverage-counts">
        <span class="cp-count cp-count-captured">✓ {screenFlowCoverage.captured} captured</span>
        <span class="cp-count cp-count-pending">⏳ {screenFlowCoverage.pending} pending</span>
        {screenFlowCoverage.failed > 0 && <span class="cp-count cp-count-failed">✗ {screenFlowCoverage.failed} failed</span>}
        <span class="cp-count cp-count-total">/ {screenFlowCoverage.total} total</span>
      </div>
    </a>
  )}

  {/* ── Tab Bar ── */}
  <div class="cp-tab-bar" role="tablist">
    <button class="cp-tab active" role="tab" aria-selected="true" data-tab="execution">Execution</button>
    <button class="cp-tab" role="tab" aria-selected="false" data-tab="observability">Observability</button>
    <button class="cp-tab" role="tab" aria-selected="false" data-tab="dashboard">Dashboard</button>
    <button class="cp-tab" role="tab" aria-selected="false" data-tab="changes">Changes</button>
  </div>

  {/* ── Tab: Execution (fully client-side for dynamic platform switching) ── */}
  <div id="tab-execution" class="cp-tab-panel not-content" role="tabpanel">
    <ExecutionTab client:visible allPlatforms={statusData.platforms || []} initialPlatformId={selectedId} />
  </div>

  {/* ── Tab: Observability ── */}
  <div id="tab-observability" class="cp-tab-panel not-content" style="display: none;" role="tabpanel">
    <ObservabilityDashboard client:load platformIds={allPlatformIds} />
  </div>

  {/* ── Tab: Dashboard ── */}
  <div id="tab-dashboard" class="cp-tab-panel not-content" style="display: none;" role="tabpanel">
    <DashboardCharts client:visible platformIds={allPlatformIds} />
  </div>

  {/* ── Tab: Changes ── */}
  <div id="tab-changes" class="cp-tab-panel not-content" style="display: none;" role="tabpanel">
    <ChangesTab client:visible repoUrl={repoUrl} />
  </div>

</StarlightPage>

<script>
  function initTabs() {
    const tabs = document.querySelectorAll<HTMLButtonElement>('.cp-tab');
    const panels = document.querySelectorAll<HTMLElement>('.cp-tab-panel');

    function activate(tabId: string) {
      tabs.forEach(t => {
        const isActive = t.dataset.tab === tabId;
        t.classList.toggle('active', isActive);
        t.setAttribute('aria-selected', String(isActive));
      });
      panels.forEach(p => {
        p.style.display = p.id === `tab-${tabId}` ? '' : 'none';
      });
      history.replaceState(null, '', `#${tabId}`);
      document.dispatchEvent(new CustomEvent('cp-tab-change', { detail: { tab: tabId } }));
    }

    tabs.forEach(t => {
      t.addEventListener('click', () => activate(t.dataset.tab!));
    });

    // Activate initial tab from hash (defaults to execution)
    const hash = location.hash.replace('#', '');
    const validTabs = ['execution', 'dashboard', 'observability', 'changes'];
    activate(validTabs.includes(hash) ? hash : 'execution');
  }

  initTabs();
  document.addEventListener('astro:after-swap', initTabs);
</script>

<style>
  /* ── Screen Capture Coverage card (epic 027 — process improvement #10) ── */
  .cp-coverage-card {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    transition: border-color 120ms ease;
  }
  .cp-coverage-card:hover { border-color: var(--sl-color-accent); }
  .cp-coverage-title {
    display: flex;
    justify-content: space-between;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .cp-coverage-pct { color: var(--sl-color-accent); font-variant-numeric: tabular-nums; }
  .cp-coverage-bar {
    height: 6px;
    background: var(--sl-color-gray-5);
    border-radius: 3px;
    overflow: hidden;
    margin-bottom: 0.5rem;
  }
  .cp-coverage-fill {
    height: 100%;
    background: var(--sl-color-accent);
    transition: width 200ms ease;
  }
  .cp-coverage-counts {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    color: var(--sl-color-gray-3);
  }
  .cp-count-captured { color: var(--sl-color-green); }
  .cp-count-failed { color: var(--sl-color-red); }

  /* ── Tab Bar ── */
  .cp-tab-bar {
    display: flex;
    gap: 0;
    border-bottom: 1px solid var(--sl-color-gray-5);
    margin-bottom: 1.25rem;
  }

  .cp-tab {
    all: unset;
    cursor: pointer;
    padding: 0.5rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--sl-color-gray-3);
    border-bottom: 2px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }

  .cp-tab:hover {
    color: var(--sl-color-white);
  }

  .cp-tab.active {
    color: var(--sl-color-white);
    font-weight: 700;
    border-bottom-color: var(--sl-color-accent);
  }

  /* ── Tokens ── */
  :root {
    --d-green: #22c55e;
    --d-amber: #f59e0b;
    --d-red: #ef4444;
    --d-gray: #6b7280;
    --d-orange: #f97316;
    --d-border: var(--sl-color-gray-5);
    --d-card: var(--sl-color-gray-7, #111);
    --d-surface: var(--sl-color-gray-6, #181818);
    --d-text: var(--sl-color-white);
    --d-text2: var(--sl-color-gray-2);
    --d-text3: var(--sl-color-gray-3);
    --d-text4: var(--sl-color-gray-4);
    --d-r: 6px;
  }

  .empty-state { text-align: center; padding: 3rem; color: var(--d-text3); }

  /* ═══ 1. HERO — stats baseline-aligned ═══ */
  .hero {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.75rem;
    padding-bottom: 1.25rem;
    border-bottom: 1px solid var(--d-border);
    flex-wrap: wrap;
  }

  .stats-row {
    display: flex;
    align-items: baseline;  /* KEY: baseline alignment */
    gap: 0;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 0 1.2rem;
    border-right: 1px solid var(--d-border);
  }
  .stat:first-child { padding-left: 0; }
  .stat:last-child { border-right: none; padding-right: 0; }

  .stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--d-text);
    line-height: 1;
    font-variant-numeric: tabular-nums;
    font-feature-settings: "tnum";
    height: 1.6rem;          /* fixed height for baseline alignment */
    display: flex;
    align-items: baseline;
  }

  .stat-unit {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--d-text3);
  }

  .stat-label {
    font-size: 0.6rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-text4);
    margin-top: 0.3rem;
    white-space: nowrap;
  }

  .next-step {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.45rem 0.75rem;
    background: var(--d-surface);
    border: 1px solid var(--d-border);
    border-radius: var(--d-r);
  }

  .next-label {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-green);
    font-weight: 700;
  }

  .next-command {
    font-size: 0.78rem;
    padding: 0.12rem 0.4rem;
    background: var(--d-card);
    border-radius: 4px;
    color: var(--d-text);
    font-weight: 500;
  }

  .next-desc {
    font-size: 0.68rem;
    color: var(--d-text3);
  }

  .done-step .next-label { color: var(--d-green); }

  /* ═══ Sections ═══ */
  .section { margin-bottom: 2rem; }

  .section-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.6rem;
  }

  .section-header h2 {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--d-text3);
  }

  .section-meta {
    font-size: 0.68rem;
    color: var(--d-text4);
  }

  /* ═══ Progress bar ═══ */
  .progress-bar-container { margin-bottom: 0.9rem; }

  .progress-bar-track {
    background: var(--d-border);
    border-radius: 2px;
    height: 3px;
    overflow: hidden;
  }

  .progress-bar-fill {
    background: var(--d-green);
    height: 100%;
    border-radius: 2px;
  }

  /* ═══ 2. LAYER CARDS — equal height via stretch ═══ */
  .layer-grid {
    display: flex;
    gap: 0.5rem;
    align-items: stretch;  /* all children same height */
  }

  @media (max-width: 900px) { .layer-grid { flex-wrap: wrap; } .layer-card { flex-basis: calc(50% - 0.25rem); } }
  @media (max-width: 550px) { .layer-card { flex-basis: 100%; } }

  .layer-card {
    flex: 1;
    border: 1px solid var(--d-border);
    border-left: 3px solid var(--layer-color);
    border-radius: var(--d-r);
    padding: 0.6rem 0.65rem;
    background: var(--d-card);
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .layer-card:hover { border-color: var(--layer-color); }
  .layer-complete { background: color-mix(in srgb, var(--layer-color) 4%, var(--d-card)); }

  .layer-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.4rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--d-border);
  }

  .layer-header h3 {
    margin: 0;
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--layer-color);
  }

  .layer-count {
    font-size: 0.65rem;
    color: var(--d-text4);
    font-variant-numeric: tabular-nums;
    font-weight: 600;
  }

  .layer-nodes { flex: 1; }

  .node-row {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.25rem;
    border-radius: 3px;
    font-size: 0.78rem;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
  }

  a.node-row:hover { background: var(--d-surface); }
  .node-row:focus-visible { outline: 2px solid var(--sl-color-accent); outline-offset: 1px; }

  .node-icon { width: 14px; text-align: center; font-weight: 700; font-size: 0.7rem; flex-shrink: 0; }
  .status-done .node-icon { color: var(--d-green); }
  .status-pending .node-icon { color: var(--d-amber); }
  .status-blocked .node-icon { color: var(--d-red); }
  .status-stale .node-icon { color: var(--d-orange); }
  .status-skipped .node-icon { color: var(--d-gray); }

  .node-name { flex: 1; color: var(--d-text2); }
  .status-done .node-name { color: var(--d-text); }
  .status-skipped .node-name { text-decoration: line-through; color: var(--d-text4); }

  .node-badge {
    font-size: 0.5rem;
    padding: 0.05rem 0.25rem;
    border-radius: 3px;
    text-transform: uppercase;
    font-weight: 700;
    background: var(--d-surface);
    color: var(--d-text4);
  }

  .node-gate { font-size: 0.6rem; flex-shrink: 0; opacity: 0.7; }

  .legend {
    display: flex;
    gap: 0.75rem;
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--d-text4);
  }
  .legend-item { display: flex; align-items: center; gap: 0.25rem; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.status-done { background: var(--d-green); }
  .dot.status-pending { background: var(--d-amber); }
  .dot.status-blocked { background: var(--d-red); }
  .dot.status-skipped { background: var(--d-gray); }
  .dot.status-stale { background: var(--d-orange); }

  /* ═══ 3. KANBAN — equal-height columns ═══ */
  .kanban-board {
    display: flex;
    gap: 0.4rem;
    align-items: stretch;  /* all columns same height */
  }

  @media (max-width: 900px) { .kanban-board { flex-wrap: wrap; } .kanban-col { flex-basis: calc(33% - 0.3rem); } }
  @media (max-width: 550px) { .kanban-col { flex-basis: calc(50% - 0.2rem); } }

  .kanban-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .col-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.3rem 0.45rem;
    background: var(--d-surface);
    border-radius: var(--d-r) var(--d-r) 0 0;
    border: 1px solid var(--d-border);
    border-bottom: none;
  }

  .col-title {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--d-text4);
  }

  .col-count {
    font-size: 0.55rem;
    background: var(--d-text3);
    color: var(--sl-color-black);
    border-radius: 8px;
    padding: 0.05rem 0.3rem;
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    min-width: 14px;
    text-align: center;
    line-height: 1.3;
  }

  .col-body {
    flex: 1;
    padding: 0.3rem;
    background: var(--d-card);
    border: 1px solid var(--d-border);
    border-radius: 0 0 var(--d-r) var(--d-r);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .epic-card {
    display: block;
    padding: 0.45rem 0.5rem;
    background: var(--d-surface);
    border: 1px solid var(--d-border);
    border-radius: 5px;
    text-decoration: none;
    color: var(--d-text);
    transition: border-color 0.15s, transform 0.1s;
  }

  .epic-card:hover {
    border-color: var(--sl-color-accent);
    transform: translateY(-1px);
  }

  .epic-card:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 1px;
  }

  .card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.1rem;
  }

  .card-id {
    font-size: 0.6rem;
    color: var(--d-text4);
    font-weight: 700;
    font-family: var(--sl-font-mono, monospace);
  }

  .card-stage {
    font-size: 0.5rem;
    padding: 0.05rem 0.25rem;
    border-radius: 3px;
    background: var(--d-card);
    color: var(--d-text4);
    text-transform: uppercase;
    font-weight: 700;
  }

  .card-title {
    display: block;
    font-size: 0.72rem;
    line-height: 1.3;
    color: var(--d-text2);
  }

  .card-progress {
    margin-top: 0.25rem;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .card-bar { flex: 1; height: 2px; background: var(--d-border); border-radius: 1px; overflow: hidden; }
  .card-fill { height: 100%; background: var(--d-green); border-radius: 1px; }
  .card-pct { font-size: 0.55rem; color: var(--d-text4); font-variant-numeric: tabular-nums; }

  .col-shipped .epic-card {
    border-left: 2px solid var(--d-green);
    opacity: 0.65;
  }

  .col-shipped .epic-card:hover {
    opacity: 0.9;
  }

  /* ═══ DAG ═══ */
  .dag-details {
    border: 1px solid var(--d-border);
    border-radius: var(--d-r);
    overflow: hidden;
  }

  .dag-summary {
    display: flex;
    align-items: baseline;
    gap: 0.6rem;
    padding: 0.6rem 0.85rem;
    cursor: pointer;
    background: var(--d-surface);
    user-select: none;
  }

  .dag-summary:hover { background: var(--d-card); }
  .dag-summary h2 { margin: 0; font-size: 0.85rem; font-weight: 600; color: var(--d-text2); }
  .dag-summary::marker { color: var(--d-text4); }

  .dag-container { height: 550px; background: var(--d-card); }

  /* ═══ Stale Alert ═══ */
  .stale-alert {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    padding: 0.55rem 0.75rem;
    background: color-mix(in srgb, var(--d-orange) 8%, var(--d-card));
    border: 1px solid color-mix(in srgb, var(--d-orange) 40%, var(--d-border));
    border-left: 3px solid var(--d-orange);
    border-radius: var(--d-r);
    margin-bottom: 1rem;
    font-size: 0.75rem;
    color: var(--d-text2);
  }

  .stale-icon { color: var(--d-orange); font-size: 0.9rem; flex-shrink: 0; line-height: 1.3; }
  .stale-content { flex: 1; }
  .stale-commands { display: block; margin-top: 0.2rem; font-family: var(--sl-font-mono, monospace); font-size: 0.68rem; color: var(--d-text3); }

  /* ═══ Footer ═══ */
  .footer-meta {
    font-size: 0.65rem;
    color: var(--d-text4);
    text-align: right;
    margin-top: 0.75rem;
    opacity: 0.6;
  }
</style>
