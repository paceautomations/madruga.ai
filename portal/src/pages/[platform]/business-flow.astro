---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import LikeC4Diagram from '../../components/viewers/LikeC4Diagram';
import { discoverPlatforms, buildViewPaths } from '../../lib/platforms.mjs';

export function getStaticPaths() {
  return discoverPlatforms()
    .filter((p) => p.views.flows?.some((f) => f.id === 'businessFlow'))
    .map((p) => ({
      params: { platform: p.name },
      props: { manifest: p },
    }));
}

const { manifest } = Astro.props;
const viewPaths = buildViewPaths(manifest);
---

<StarlightPage frontmatter={{ title: 'Business Process — Pipeline Completo', tableOfContents: false }}>
  <div class="diagram-fullscreen">
    <LikeC4Diagram viewId="businessFlow" platform={manifest.name} viewPaths={viewPaths} client:only="react" />
  </div>
</StarlightPage>
