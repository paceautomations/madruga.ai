---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { discoverPlatforms } from '../../lib/platforms.mjs';

export function getStaticPaths() {
  return discoverPlatforms().map((p) => ({
    params: { platform: p.name },
    props: { platform: p.name },
  }));
}

const { platform } = Astro.props;

const allEpicFiles = import.meta.glob(
  '/src/content/docs/*/epics/*/pitch.md',
  { eager: true },
);

const epics = Object.entries(allEpicFiles)
  .filter(([path]) => path.includes(`/${platform}/`))
  .map(([path, mod]) => {
    const fm = (mod as any).frontmatter ?? {};
    const segments = path.split('/');
    const epicDir = segments[segments.length - 2];
    return { dir: epicDir, ...fm };
  })
  .sort((a, b) => String(a.id ?? '').localeCompare(String(b.id ?? '')));

const phases = [
  { key: 'now', label: 'Now' },
  { key: 'next', label: 'Next' },
  { key: 'later', label: 'Later' },
];

const doneEpics = epics.filter((e) => e.status === 'done');
---

<StarlightPage frontmatter={{ title: 'Roadmap', tableOfContents: false }}>
  {phases.map((phase) => {
    const items = epics.filter((e) => e.phase === phase.key && e.status !== 'done');
    return items.length > 0 ? (
      <section>
        <h2>{phase.label}</h2>
        <table>
          <thead>
            <tr>
              <th>#</th>
              <th>Epic</th>
              <th>Status</th>
              <th>Contexts</th>
            </tr>
          </thead>
          <tbody>
            {items.map((e) => (
              <tr>
                <td>{e.id}</td>
                <td>
                  <a href={`/${platform}/epics/${e.dir}/pitch/`}>
                    <strong>{e.title}</strong>
                  </a>
                </td>
                <td>{e.status ?? '—'}</td>
                <td>{(e.arch?.contexts ?? []).join(', ') || '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    ) : null;
  })}

  {doneEpics.length > 0 ? (
    <section>
      <h2>Done</h2>
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Epic</th>
            <th>Outcome</th>
          </tr>
        </thead>
        <tbody>
          {doneEpics.map((e) => (
            <tr>
              <td>{e.id}</td>
              <td>
                <a href={`/${platform}/epics/${e.dir}/pitch/`}>
                  <strong>{e.title}</strong>
                </a>
              </td>
              <td>{e.outcome ?? '—'}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </section>
  ) : null}
</StarlightPage>
