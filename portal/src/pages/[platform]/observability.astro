---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import ObservabilityDashboard from '../../components/observability/ObservabilityDashboard.tsx';
import { discoverPlatforms } from '../../lib/platforms.mjs';

export function getStaticPaths() {
  return discoverPlatforms().map((p) => ({
    params: { platform: p.name },
    props: { manifest: p },
  }));
}

const { manifest } = Astro.props;
const platformName = manifest.name;
---

<StarlightPage frontmatter={{ title: `Observability`, tableOfContents: false }}>
  <ObservabilityDashboard client:load platform={platformName} />
</StarlightPage>
