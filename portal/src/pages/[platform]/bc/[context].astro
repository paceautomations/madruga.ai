---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import LikeC4Diagram from '../../../components/viewers/LikeC4Diagram';
import { discoverPlatforms, buildViewPaths } from '../../../lib/platforms.mjs';

export function getStaticPaths() {
  const paths = [];
  for (const p of discoverPlatforms()) {
    const bcViews = p.views.structural.filter((v) => v.id.endsWith('Detail'));
    for (const view of bcViews) {
      const context = view.id.replace('Detail', '').toLowerCase();
      paths.push({
        params: { platform: p.name, context },
        props: { manifest: p, viewId: view.id, label: view.label },
      });
    }
  }
  return paths;
}

const { manifest, viewId, label } = Astro.props;
const viewPaths = buildViewPaths(manifest);
---

<StarlightPage frontmatter={{ title: label, tableOfContents: false }}>
  <div class="diagram-fullscreen">
    <LikeC4Diagram viewId={viewId} platform={manifest.name} viewPaths={viewPaths} client:only="react" />
  </div>
</StarlightPage>
