---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { discoverPlatforms, loadStatusData } from '../../lib/platforms.mjs';

export function getStaticPaths() {
  return discoverPlatforms().map((p) => ({
    params: { platform: p.name },
    props: { platform: p.name },
  }));
}

const { platform } = Astro.props;

// Primary: read from pipeline-status.json (single source of truth via DB)
let decisions: any[] = [];
try {
  const statusData = loadStatusData();
  const platformData = (statusData?.platforms || []).find((p: any) => p.id === platform);
  decisions = platformData?.decisions || [];
} catch { /* not generated yet */ }

// Fallback: read from markdown frontmatter if JSON has no decisions
if (decisions.length === 0) {
  const allAdrFiles = import.meta.glob(
    '/src/content/docs/*/decisions/ADR-*.md',
    { eager: true },
  );

  decisions = Object.entries(allAdrFiles)
    .filter(([path]) => path.includes(`/${platform}/`))
    .map(([path, mod]) => {
      const fm = (mod as any).frontmatter ?? {};
      const slug = path.split('/').pop()!.replace('.md', '');
      const num = slug.match(/ADR-(\d+)/)?.[1] ?? '000';
      return { slug, num, ...fm };
    })
    .sort((a, b) => a.num.localeCompare(b.num));
}
---

<StarlightPage frontmatter={{ title: 'Decision Overviews', tableOfContents: false }}>
  <table>
    <thead>
      <tr>
        <th>ADR</th>
        <th>Decisao</th>
        <th>Alternativa descartada</th>
        <th>Motivo</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      {decisions.map((adr: any) => {
        const num = adr.num || '000';
        const slug = adr.slug || `ADR-${num}`;
        return (
          <tr>
            <td>
              <a href={`/${platform}/decisions/${slug.toLowerCase()}/`}>ADR-{num}</a>
            </td>
            <td>{adr.decision ?? '—'}</td>
            <td>{adr.alternatives ?? '—'}</td>
            <td>{adr.rationale ?? '—'}</td>
            <td>{adr.status ?? '—'}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</StarlightPage>
