---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { discoverPlatforms, buildSidebar } from '../lib/platforms.mjs';

const platforms = discoverPlatforms();
const singlePlatform = platforms.length === 1 ? platforms[0] : null;
const sidebar = buildSidebar(platforms);
---

{singlePlatform ? (
  <html>
    <head>
      <meta http-equiv="refresh" content={`0;url=/${singlePlatform.name}/control-panel/`} />
      <link rel="canonical" href={`/${singlePlatform.name}/control-panel/`} />
    </head>
    <body>
      <p>Redirecionando para <a href={`/${singlePlatform.name}/control-panel/`}>{singlePlatform.title}</a>...</p>
      <script define:vars={{ url: `/${singlePlatform.name}/control-panel/` }}>
        window.location.replace(url);
      </script>
    </body>
  </html>
) : (
  <StarlightPage frontmatter={{ title: 'Plataformas', tableOfContents: false }} sidebar={sidebar}>
    <p>Selecione uma plataforma para visualizar sua documentação arquitetural.</p>
    <div class="platform-cards">
      {platforms.map((p) => (
        <a href={`/${p.name}/control-panel/`} class="platform-card">
          <h2>{p.title}</h2>
          <p>{p.description}</p>
          <span class="badge">{p.lifecycle}</span>
        </a>
      ))}
    </div>
  </StarlightPage>
)}
