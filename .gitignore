# A1: the runtime DB is reproduced from filesystem via `make seed` — tracking
# it in git caused WAL corruption on `git checkout`/`stash` because WAL/SHM
# siblings were gitignored while the main file was tracked.
.pipeline/madruga.db
.pipeline/madruga.db-wal
.pipeline/madruga.db-shm
.pipeline/madruga.db-journal
.pipeline/madruga.lock
.pipeline/madruga-db.lock
.pipeline/*.bak*
.pipeline/backups/
.pipeline/logs/
.pipeline/timeout-diagnostics/
platforms/*/model/output/
.env
htmlcov/
.coverage
.claude/scheduled_tasks.lock
# Defensive: external platform code must never exist at madruga.ai root.
# Pipeline migrations live at .pipeline/migrations/, not /migrations/.
# madruga.ai is a documentation system, not a Docker app.
/migrations/
/docker-compose*.yml
