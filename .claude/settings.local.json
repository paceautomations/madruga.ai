{
  "permissions": {
    "allow": [
      "Bash",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(.specify/**)",
      "Write(.specify/**)",
      "Edit",
      "Read",
      "Write",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Task",
      "Skill",
      "NotebookEdit",
      "ToolSearch",
      "mcp__*",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_install",
      "mcp__playwright__browser_type",
      "mcp__playwright__browser_click",
      "mcp__playwright__browser_wait_for",
      "mcp__playwright__browser_take_screenshot",
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_run_code",
      "Bash(git branch:*)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__granola-mcp__list_meetings",
      "mcp__granola-mcp__get_recent_meetings",
      "mcp__granola-mcp__get_meeting",
      "mcp__granola-mcp__get_meeting_notes",
      "mcp__granola-mcp__get_transcript",
      "mcp__youtube-transcript__get_transcript",
      "mcp__google-workspace__search_gmail_messages",
      "mcp__google-workspace__get_gmail_messages_content_batch",
      "mcp__ms365__list-accounts",
      "mcp__ms365__login",
      "mcp__ms365__list-mail-messages",
      "mcp__google-workspace__list_script_projects",
      "mcp__google-workspace__create_script_project",
      "mcp__google-workspace__update_script_content",
      "mcp__google-workspace__run_script_function",
      "mcp__google-workspace__get_script_project",
      "mcp__google-workspace__get_script_content",
      "mcp__google-workspace__list_gmail_labels",
      "mcp__google-workspace__modify_gmail_message_labels",
      "mcp__google-workspace__batch_modify_gmail_message_labels",
      "mcp__ms365__verify-login",
      "mcp__ms365__list-mail-folders",
      "mcp__ms365__move-mail-message",
      "mcp__ms365__get-mail-message",
      "mcp__google-workspace__start_google_auth",
      "mcp__google-workspace__list_gmail_filters",
      "mcp__google-workspace__get_gmail_message_content",
      "mcp__google-workspace__get_gmail_attachment_content",
      "mcp__google-workspace__get_events",
      "mcp__ms365__get-calendar-view",
      "mcp__playwright__browser_close",
      "mcp__google-workspace__send_gmail_message",
      "mcp__ms365__list-calendars",
      "mcp__ms365__get-specific-calendar-view",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_resize",
      "mcp__whatsapp__send_whatsapp",
      "mcp__whatsapp__send_whatsapp_media",
      "mcp__ms365__remove-account",
      "mcp__playwright__browser_console_messages",
      "mcp__playwright__browser_press_key",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "mcp__playwright__browser_network_requests"
    ],
    "deny": [],
    "defaultMode": "dontAsk"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "supabase",
    "whatsapp"
  ],
  "disabledMcpjsonServers": [
    "perplexity",
    "firecrawl",
    "sequential-thinking"
  ],
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .specify/scripts/hook_post_save.py 2>/dev/null || true",
            "timeout": 30
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .specify/scripts/hook_skill_lint.py 2>/dev/null || true",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
